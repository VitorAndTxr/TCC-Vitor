    SNOMED_BODY_STRUCTURE {
        string SnomedCode PK
        string BodyRegionCode FK
        string DisplayName
        string StructureType
        string ParentStructureCode FK
        bool IsActive
    }

    SNOMED_BODY_REGION {
        string SnomedCode PK
        string DisplayName
        string ParentRegionCode FK
        string Description
        bool IsActive
    }

    SNOMED_TOPOGRAPHICAL_MODIFIER {
        string Code PK
        string DisplayName
        string Category
        string Description
        bool IsActive
    }

    SNOMED_LATERALITY {
        string Code PK
        string DisplayName
        string Description
