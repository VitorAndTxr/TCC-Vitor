    }

    VOLUNTEER_CLINICAL_CONDITION {
        uuid Id PK
        uuid VolunteerId FK
        string SnomedCode FK
        string ClinicalStatus
        uuid RecordedBy FK
        timestamp CreatedAt
        timestamp UpdatedAt
