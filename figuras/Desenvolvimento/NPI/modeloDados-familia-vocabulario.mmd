    TARGET_AREA_TOPOGRAPHICAL_MODIFIER {
        uuid TargetAreaId FK
        string TopographicalModifierCode FK
    }

    %% Entidades de outras familias citadas em relacionamentos
    VOLUNTEER { }
    TARGET_AREA { }

    %% Relacionamentos internos
    SNOMED_BODY_STRUCTURE ||--o| SNOMED_BODY_REGION : pertence
    SNOMED_BODY_REGION ||--o{ SNOMED_BODY_REGION : hierarquia
    SNOMED_BODY_STRUCTURE ||--o{ SNOMED_BODY_STRUCTURE : hierarquia

    %% Relacionamentos com outras familias
    VOLUNTEER }o--o{ CLINICAL_CONDITION : VOLUNTEER_CLINICAL_CONDITION
    TARGET_AREA ||--|| SNOMED_BODY_STRUCTURE : refere
    TARGET_AREA ||--o| SNOMED_LATERALITY : tem
    TARGET_AREA }o--o{ SNOMED_TOPOGRAPHICAL_MODIFIER : TARGET_AREA_TOPOGRAPHICAL_MODIFIER
